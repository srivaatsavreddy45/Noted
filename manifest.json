{
  "manifest_version": 3,
  "name": "Noted – Tasks & Notes",
  "version": "1.0.0",
  "description": "Advanced to-do list and note-taking. Capture tasks, write notes, and stay organized from any tab.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Noted – Tasks & Notes"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "alarms", "notifications"],
  "background": {
    "service_worker": "background.js"
  }
}
